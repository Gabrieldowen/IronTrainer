# Application
APP_ENV=development
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Public base URL of this backend — used to build links the bot sends
# users (e.g. the personalized Strava connect link). Locally, use your
# ngrok URL; in production, your real Render URL.
APP_BASE_URL=https://your-ngrok-or-render-url.example.com

# Database (Supabase Postgres connection string)
# Found in Supabase dashboard: Project Settings > Database > Connection string (URI, "Session pooler" or "Transaction pooler" mode)
# IMPORTANT: use the pooler connection string, not the direct connection, for production
# Format: postgresql://postgres.[project-ref]:[password]@[host]:[port]/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Database pool sizing
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

STRAVA_CLIENT_ID=your_actual_client_id
STRAVA_CLIENT_SECRET=your_actual_client_secret
STRAVA_REDIRECT_URI=${APP_BASE_URL}/strava/callback

# Strava Webhooks
# This is a secret string YOU make up (not provided by Strava) — used to
# verify webhook handshake requests are genuinely coming from Strava's
# subscription setup, not a random party guessing your webhook URL.
STRAVA_WEBHOOK_VERIFY_TOKEN=choose_any_random_secret_string

# Internal/admin endpoints
# A secret you choose — required as the X-Internal-API-Key header to
# call internal maintenance endpoints (e.g. the replay endpoint).
INTERNAL_API_KEY=choose_another_random_secret_string

# AI Coaching (LLM provider)
# Currently configured for Groq (https://console.groq.com) — free tier,
# no credit card required. Uses the OpenAI-compatible client, so
# switching to any other OpenAI-compatible provider (OpenAI itself,
# Cerebras, Together AI, etc.) later is just changing these 3 values.
LLM_API_KEY=your_groq_api_key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Discord bot
DISCORD_BOT_TOKEN=your_discord_bot_token
