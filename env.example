# Application
APP_ENV=development
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database (Supabase Postgres connection string)
# Found in Supabase dashboard: Project Settings > Database > Connection string (URI, "Session pooler" or "Transaction pooler" mode)
# IMPORTANT: use the pooler connection string, not the direct connection, for production
# Format: postgresql://postgres.[project-ref]:[password]@[host]:[port]/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Database pool sizing
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10